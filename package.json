{
  "name": "resume-cooker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:pdf": "node generator/scripts/build-pdf.mjs",
    "preview": "node generator/scripts/preview-server.mjs",
    "check:tools": "node generator/scripts/check-tools.mjs",
    "check:local": "node checker/scripts/check.mjs --suite local --resume resume/source/current.tex --jd fixtures/software_engineering_intern_jd.txt --out .runtime/reports/local-check.json",
    "check:api": "node checker/scripts/check.mjs --suite api --resume resume/source/current.tex --jd fixtures/software_engineering_intern_jd.txt --out .runtime/reports/api-check.json",
    "check:full": "node checker/scripts/check.mjs --suite full --resume resume/source/current.tex --jd fixtures/software_engineering_intern_jd.txt --out .runtime/reports/full-check.json",
    "compare": "node checker/scripts/compare.mjs --before resume/source/current.tex --after resume/source/current.tex --out .runtime/reports/compare.json",
    "format": "prettier --write \"**/*.{md,json,yml,yaml,html,js,mjs}\"",
    "format:check": "prettier --check \"**/*.{md,json,yml,yaml,html,js,mjs}\"",
    "lint": "eslint .",
    "test": "node --test \"generator/scripts/*.test.mjs\" \"checker/scripts/*.test.mjs\"",
    "ci": "npm run format:check && npm run lint && npm test && npm run check:tools"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^10.0.0",
    "prettier": "^3.0.0"
  }
}
